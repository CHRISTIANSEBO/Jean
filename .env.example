# ── Required secrets — paste these into Railway dashboard → Variables ─────────

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ── Deployment config ─────────────────────────────────────────────────────────

# Set to "production" on Railway
FLASK_ENV=production

# Railway injects PORT automatically — do not set this yourself on Railway
# PORT=5000

# Your Railway public URL — found in Railway dashboard → Settings → Domains
# e.g. https://jean-production.up.railway.app
OAUTH_CALLBACK_URL=https://YOUR-APP.up.railway.app/auth/callback
FRONTEND_URL=https://YOUR-APP.up.railway.app

# ── Google OAuth ──────────────────────────────────────────────────────────────
# credentials.json cannot be committed. On Railway, encode it as a single env var:
#   base64 -w 0 credentials.json   (Linux)
#   base64 -i credentials.json     (macOS)
# Then paste the result here and Railway will write it to disk at startup.
GOOGLE_CREDENTIALS_B64=<base64-encoded contents of credentials.json>
